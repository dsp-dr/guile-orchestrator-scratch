# direnv configuration for Guile Orchestrator development
# Usage: direnv allow

# Add src directory to Guile load path
export GUILE_LOAD_PATH="${PWD}/src:${GUILE_LOAD_PATH}"
export GUILE_LOAD_COMPILED_PATH="${PWD}/build:${GUILE_LOAD_COMPILED_PATH}"

# Development environment variables
export ORCHESTRATOR_ENV="development"
export ORCHESTRATOR_LOG_LEVEL="debug"
export ORCHESTRATOR_DATA_DIR="${PWD}/tmp/data"

# FreeBSD-specific settings
export ORCHESTRATOR_USE_KQUEUE="1"
export ORCHESTRATOR_JAIL_SUPPORT="0"  # Disabled by default in dev

# Guile optimization flags
export GUILE_AUTO_COMPILE="1"
export GUILE_WARN_DEPRECATED="detailed"

# Create necessary directories
mkdir -p tmp/data tmp/logs build

# Load local overrides if they exist
if [ -f .envrc.local ]; then
    source .envrc.local
fi

echo "Guile Orchestrator development environment loaded"
echo "  GUILE_LOAD_PATH: ${GUILE_LOAD_PATH}"
echo "  ORCHESTRATOR_ENV: ${ORCHESTRATOR_ENV}"